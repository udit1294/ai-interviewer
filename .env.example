# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/database_name?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/ai_interviewer?schema=public"

# Groq API Configuration
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# JWT Secret (for authentication)
# Generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# NextAuth Configuration (if using NextAuth.js)
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Optional: PostgreSQL Admin Details (for local development)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_interviewer

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Supabase Storage Configuration (Replaces AWS S3)
NEXT_PUBLIC_SUPABASE_URL=https://qdlyrxycctqhjosjrnlt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=key
SUPABASE_SERVICE_ROLE_KEY=key

# Resend Email Notification API
RESEND_API_KEY=your-resend-api-key-here

# TTS Audio Processing Interface API
OPENAI_API_KEY=your-openai-api-key-here
